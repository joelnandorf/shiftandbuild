---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  pillar: string;
  heroImage?: ImageMetadata;
  heroImageAlt?: string;
}

const { title, description, pubDate, updatedDate, tags, pillar, heroImage, heroImageAlt } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const pillarLabels: Record<string, string> = {
  'ai-arkitektur': 'AI-arkitektur',
  'tech-lead': 'Tech lead',
  'rollkonvergens': 'Rollkonvergens',
};

const dateOptions: Intl.DateTimeFormatOptions = {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
};
---

<BaseLayout
  title={`${title} — Shift+Build`}
  description={description}
  canonicalURL={canonicalURL}
  ogTitle={title}
  ogDescription={description}
>
  <article class="app-layout py-12 md:py-16">
    {heroImage && (
      <Image
        src={heroImage}
        alt={heroImageAlt ?? ''}
        class="w-full h-auto rounded-lg mb-10"
        widths={[400, 800, 1200]}
        sizes="(min-width: 44rem) 44rem, 100vw"
      />
    )}
    <header class="mb-10 pb-8 border-b border-slate-200">
      <div class="flex items-center gap-3 flex-wrap mb-4">
        <span class="text-xs font-semibold tracking-widest uppercase text-indigo-600 bg-indigo-50 px-2.5 py-1 rounded">
          {pillarLabels[pillar] ?? pillar}
        </span>
        <time
          datetime={pubDate.toISOString()}
          class="text-sm text-slate-500"
        >
          {pubDate.toLocaleDateString('sv-SE', dateOptions)}
        </time>
        {updatedDate && updatedDate > pubDate && (
          <span class="text-sm text-slate-500 italic">
            Uppdaterad {updatedDate.toLocaleDateString('sv-SE', dateOptions)}
          </span>
        )}
      </div>

      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight leading-tight mb-3">
        {title}
      </h1>
      <p class="text-lg text-slate-500 leading-relaxed">
        {description}
      </p>

      {tags.length > 0 && (
        <div class="flex gap-2 flex-wrap mt-4">
          {tags.map(tag => (
            <span class="font-mono text-xs text-slate-500 bg-slate-100 border border-slate-200 rounded px-2 py-0.5">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-slate max-w-none prose-img:rounded-lg">
      <slot />
    </div>

    <footer class="mt-12">
      <hr class="border-slate-200 mb-8" />
      <div class="bg-slate-50 border border-slate-200 rounded-lg p-5 mb-6">
        <p class="text-sm mb-1">
          <strong>Joel Nandorf</strong> är tech lead i Umeå och skriver om AI-arkitektur,
          tekniskt ledarskap och hur rollerna inom produktutveckling konvergerar.
        </p>
        <p class="text-sm text-slate-500">
          Gillade du det här? Följ via{' '}
          <a href={`${base}/rss.xml`} class="text-indigo-600 hover:underline">RSS</a> eller hör av dig på{' '}
          <a
            href="https://www.linkedin.com/in/joelnandorf"
            rel="noopener noreferrer"
            target="_blank"
            class="text-indigo-600 hover:underline"
          >LinkedIn</a> — jag svarar gärna.
        </p>
      </div>
      <a
        href={base || '/'}
        class="text-sm text-slate-500 hover:text-indigo-600 transition-colors"
      >
        ← Alla inlägg
      </a>
    </footer>
  </article>
</BaseLayout>
